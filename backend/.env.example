# ─── Server ────────────────────────────────────────────────────────
PORT=5000

# ─── PostgreSQL (khớp với docker-compose.yml) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartlife
DB_USER=root
DB_PASSWORD=rootpassword

# ─── Google Gemini AI ───────────────────────────────────────────────
# Lấy key miễn phí tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
